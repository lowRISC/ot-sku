// The OT00 owner keys were generated by the following command:
// hsmtool -t <token> -u user -p <pin> exec keygen_owner.hjson

[
  ////////////////////////////////////////////////////////////////////////////
  //
  // There are 3 ownership keys: owner, activate and unlock.
  // We need both ecdsa and slhdsa keys.
  //
  ////////////////////////////////////////////////////////////////////////////
  {
    command: "ecdsa-generate",
    label: "nuvoton-ot00-owner-ecdsa-0"
    curve: "1.2.840.10045.3.1.7",
    wrapping: false,
    extractable: false,
    public_template: {
          CKA_CLASS: "CKO_PUBLIC_KEY",
          CKA_KEY_TYPE: "CKK_EC",
          CKA_TOKEN: true,
          CKA_ENCRYPT: false,
          CKA_VERIFY: true
    },
    private_template: {
          CKA_CLASS: "CKO_PRIVATE_KEY",
          CKA_KEY_TYPE: "CKK_EC",
          CKA_TOKEN: true,
          // The key is valid for signing, but not decryption or unwrapping.
          CKA_SIGN: true
          CKA_DECRYPT: false,
          CKA_UNWRAP: false,
          // The key is extractable as required for importing into another HSM.
          CKA_EXTRACTABLE: true,
          // The key may not be accessed until the user has authenticated
          // to the HSM.
          CKA_PRIVATE: true,
          // The keys may be exported in plaintext so that they can be
          // imported into another HSM.
          CKA_SENSITIVE: false,
          CKA_MODIFIABLE: true,
          CKA_DESTROYABLE: false,
    },
  },
  {
    command: "ecdsa-generate",
    label: "nuvoton-ot00-activate-ecdsa-0"
    curve: "1.2.840.10045.3.1.7",
    wrapping: false,
    extractable: false,
    public_template: {
          CKA_CLASS: "CKO_PUBLIC_KEY",
          CKA_KEY_TYPE: "CKK_EC",
          CKA_TOKEN: true,
          CKA_ENCRYPT: false,
          CKA_VERIFY: true
    },
    private_template: {
          CKA_CLASS: "CKO_PRIVATE_KEY",
          CKA_KEY_TYPE: "CKK_EC",
          CKA_TOKEN: true,
          // The key is valid for signing, but not decryption or unwrapping.
          CKA_SIGN: true
          CKA_DECRYPT: false,
          CKA_UNWRAP: false,
          // The key is extractable as required for importing into another HSM.
          CKA_EXTRACTABLE: true,
          // The key may not be accessed until the user has authenticated
          // to the HSM.
          CKA_PRIVATE: true,
          // The keys may be exported in plaintext so that they can be
          // imported into another HSM.
          CKA_SENSITIVE: false,
          CKA_MODIFIABLE: true,
          CKA_DESTROYABLE: false,
    },
  },
  {
    command: "ecdsa-generate",
    label: "nuvoton-ot00-unlock-ecdsa-0"
    curve: "1.2.840.10045.3.1.7",
    wrapping: false,
    extractable: false,
    public_template: {
          CKA_CLASS: "CKO_PUBLIC_KEY",
          CKA_KEY_TYPE: "CKK_EC",
          CKA_TOKEN: true,
          CKA_ENCRYPT: false,
          CKA_VERIFY: true
    },
    private_template: {
          CKA_CLASS: "CKO_PRIVATE_KEY",
          CKA_KEY_TYPE: "CKK_EC",
          CKA_TOKEN: true,
          // The key is valid for signing, but not decryption or unwrapping.
          CKA_SIGN: true
          CKA_DECRYPT: false,
          CKA_UNWRAP: false,
          // The key is extractable as required for importing into another HSM.
          CKA_EXTRACTABLE: true,
          // The key may not be accessed until the user has authenticated
          // to the HSM.
          CKA_PRIVATE: true,
          // The keys may be exported in plaintext so that they can be
          // imported into another HSM.
          CKA_SENSITIVE: false,
          CKA_MODIFIABLE: true,
          CKA_DESTROYABLE: false,
    },
  },

  {
    command: "spx-generate",
    label: "nuvoton-ot00-owner-slhdsa-0"
    export: "nuvoton-ot00-owner-slhdsa-0.priv.pem"
    algorithm: "SPHINCS+-SHA2-128s-simple",
    domain: "PreHashedSha256",
    overwrite: false,
  },
  {
    command: "spx-generate",
    label: "nuvoton-ot00-activate-slhdsa-0"
    export: "nuvoton-ot00-activate-slhdsa-0.priv.pem"
    algorithm: "SPHINCS+-SHA2-128s-simple",
    domain: "PreHashedSha256",
    overwrite: false,
  },
  {
    command: "spx-generate",
    label: "nuvoton-ot00-unlock-slhdsa-0"
    export: "nuvoton-ot00-unlock-slhdsa-0.priv.pem"
    algorithm: "SPHINCS+-SHA2-128s-simple",
    domain: "PreHashedSha256",
    overwrite: false,
  },

]

